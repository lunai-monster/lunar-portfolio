---
import { Home, Briefcase, Trophy, User, Code, Github } from '@lucide/astro';

interface Props {
  currentPage?: 'home' | 'work' | 'experiences' | 'about' | 'skills';
  delayAnimation?: boolean;
}

const { currentPage = 'home', delayAnimation = false } = Astro.props;
---

<nav 
  class={`bottom-nav fixed bottom-8 left-8 z-50 ${delayAnimation ? 'animate-bottom-nav-delayed' : 'animate-bottom-nav'}`} 
  id="bottom-nav"
  data-delay-animation={delayAnimation}
>
  <div class="bg-zinc-900/90 backdrop-blur-xl border border-zinc-800 rounded-full px-4 py-3 shadow-2xl shadow-black/50 transition-all duration-300">
    <ul class="flex items-center gap-4">
      <li>
        <a 
          href="/" 
          class={`flex items-center justify-center transition-all group ${currentPage === 'home' ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
          aria-label="Home"
        >
          <Home 
            size={20} 
            class={`transition-transform ${currentPage === 'home' ? 'scale-110' : 'group-hover:scale-110'}`}
          />
        </a>
      </li>

      <li class="w-px h-6 bg-zinc-800"></li>

      <li>
        <a 
          href="/work" 
          class={`flex items-center justify-center transition-all group ${currentPage === 'work' ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
          aria-label="Work"
        >
          <Briefcase 
            size={20} 
            class={`transition-transform ${currentPage === 'work' ? 'scale-110' : 'group-hover:scale-110'}`}
          />
        </a>
      </li>

      <li class="w-px h-6 bg-zinc-800"></li>

      <li>
        <a 
          href="/experiences" 
          class={`flex items-center justify-center transition-all group ${currentPage === 'experiences' ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
          aria-label="Experiences"
        >
          <Trophy 
            size={20} 
            class={`transition-transform ${currentPage === 'experiences' ? 'scale-110' : 'group-hover:scale-110'}`}
          />
        </a>
      </li>

      <li class="w-px h-6 bg-zinc-800"></li>

      <li>
        <a 
          href="/about" 
          class={`flex items-center justify-center transition-all group ${currentPage === 'about' ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
          aria-label="About"
        >
          <User 
            size={20} 
            class={`transition-transform ${currentPage === 'about' ? 'scale-110' : 'group-hover:scale-110'}`}
          />
        </a>
      </li>

      <li class="w-px h-6 bg-zinc-800"></li>

      <li>
        <a 
          href="/skills" 
          class={`flex items-center justify-center transition-all group ${currentPage === 'skills' ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
          aria-label="Skills"
        >
          <Code 
            size={20} 
            class={`transition-transform ${currentPage === 'skills' ? 'scale-110' : 'group-hover:scale-110'}`}
          />
        </a>
      </li>

      <li class="w-px h-6 bg-zinc-800"></li>

      <li>
        <a 
          href="https://github.com/xyztavo" 
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center transition-all group text-zinc-400 hover:text-white"
          aria-label="GitHub"
        >
          <Github 
            size={20} 
            class="transition-transform group-hover:scale-110"
          />
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const nav = document.getElementById('bottom-nav');
  const hasDelay = nav?.getAttribute('data-delay-animation') === 'true';
  let animationComplete = !hasDelay;
  
  // If delayed animation, wait for it to complete
  if (hasDelay && nav) {
    setTimeout(() => {
      animationComplete = true;
      // Remove animation class and add transition class
      nav.classList.remove('animate-bottom-nav-delayed');
      nav.classList.add('nav-interactive');
      // Set initial state after animation
      nav.style.opacity = '0.3';
      nav.style.transform = 'translateY(10px)';
      enableProximityEffect();
    }, 4600); // 4s delay + 0.6s animation
  } else if (nav) {
    nav.classList.add('nav-interactive');
    enableProximityEffect();
  }

  function enableProximityEffect() {
    if (!nav) return;

    if (window.innerWidth >= 768) {
      // Desktop: show on mouse proximity
      document.addEventListener('mousemove', (e) => {
        if (!animationComplete) return;

        const navRect = nav.getBoundingClientRect();
        const distance = Math.sqrt(
          Math.pow(e.clientX - (navRect.left + navRect.width / 2), 2) +
          Math.pow(e.clientY - (navRect.top + navRect.height / 2), 2)
        );
        
        // Reveal if mouse is within 200px
        if (distance < 200) {
          nav.style.opacity = '1';
          nav.style.transform = 'translateY(0)';
        } else {
          nav.style.opacity = '0.3';
          nav.style.transform = 'translateY(10px)';
        }
      });
    } else {
      // Mobile: always visible after animation
      if (animationComplete) {
        nav.style.opacity = '1';
        nav.style.transform = 'translateY(0)';
      }
    }
  }
</script>

<style>
  .animate-bottom-nav {
    opacity: 0.3;
  }

  .animate-bottom-nav-delayed {
    opacity: 0;
    animation: fadeInNav 0.6s ease-out 4s forwards;
  }

  .nav-interactive {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @keyframes fadeInNav {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 0.3;
      transform: translateY(10px);
    }
  }

  @media (max-width: 767px) {
    .animate-bottom-nav {
      opacity: 1;
    }
    
    .animate-bottom-nav-delayed {
      animation: fadeInNavMobile 0.6s ease-out 4s forwards;
    }

    @keyframes fadeInNavMobile {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
</style>
