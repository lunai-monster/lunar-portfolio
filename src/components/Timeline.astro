---
import { Briefcase, GraduationCap, MapPin } from '@lucide/astro';

const experiences = [
  {
    type: "work",
    company: "ServeCommand",
    location: "NY, Remote",
    role: "Dev Fullstack Freelance",
    period: "August 2025 - November 2025",
    description: "Collaborated in development as a remote freelance role on the project, developed features like slash commands and a new activity registration flow. The project is focused on corporate team and task administration.",
    technologies: ["Drizzle", "PostgreSQL", "NextJs", "Local-First", "Proprietary Sync Engine"]
  },
  {
    type: "work",
    company: "Car Ja",
    location: "São Paulo",
    role: "Dev Fullstack Freelance",
    period: "Since November 2025",
    description: "Developed a FullStack e-commerce platform focused on point-of-sale for car parts, with microservices payment gateway integration and RAG.",
    technologies: ["Golang", "NextJs"]
  },
  {
    type: "work",
    company: "Direção Positiva",
    location: "São Paulo",
    role: "Dev Fullstack Freelance",
    period: "Since November 2025",
    description: "Developed a Full-Stack application for driving instructors and students, with Google Maps API integration.",
    technologies: ["React", "Golang"]
  },
  {
    type: "education",
    company: "Etec Irmã Agostina",
    location: "Autódromo Interlagos, SP",
    role: "Systems Development",
    period: "June 2023 - December 2025",
    description: "Studied systems analysis and development, developed full stack projects like the final graduation project (TCC) using knowledge of CI/CD, Hosting, SEO, and Web Development.",
    technologies: ["Typescript", "NestJs", "NextJs"]
  },
  {
    type: "education",
    company: "Fatec Zona Sul",
    location: "São Paulo, SP",
    role: "Systems Development",
    period: "Since February 2026",
    description: "Started the systems analysis and development course at Fatec Zona Sul.",
    technologies: []
  }
];
---

<div class="relative">
  <!-- Timeline Line -->
  <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-gradient-to-b from-zinc-800 via-zinc-700 to-zinc-800 timeline-line"></div>

  <!-- Timeline Items -->
  {experiences.map((exp, index) => (
    <div 
      class={`relative mb-16 timeline-item animate-timeline`}
      style={`animation-delay: ${index * 0.2}s`}
    >
      <div class={`flex items-center gap-8 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
        <!-- Timeline Dot -->
        <div class="absolute left-8 md:left-1/2 transform -translate-x-1/2 z-10">
          <div class="w-4 h-4 rounded-full border-4 bg-white border-zinc-600 timeline-dot">
          </div>
        </div>

        <!-- Content Card -->
        <div class={`ml-20 md:ml-0 md:w-5/12 ${index % 2 === 0 ? 'md:text-right md:pr-12' : 'md:pl-12'}`}>
          <div class="bg-zinc-900/50 backdrop-blur-sm border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all hover:shadow-xl hover:shadow-white/5">
            <!-- Period Badge -->
            <span class="inline-block text-xs font-semibold px-3 py-1 rounded-full bg-zinc-800 text-zinc-300 mb-3">
              {exp.period}
            </span>
            
            <!-- Company & Role -->
            <h3 class="text-2xl font-bold text-white mb-2">
              {exp.company}
            </h3>
            <p class="text-lg text-zinc-300 mb-2">
              {exp.role}
            </p>
            <p class="inline-flex items-center gap-1.5 text-sm text-zinc-500 mb-4">
              <MapPin size={14} />
              {exp.location}
            </p>

            <!-- Description -->
            <p class="text-zinc-400 mb-4">
              {exp.description}
            </p>

            <!-- Technologies -->
            {exp.technologies.length > 0 && (
              <div class="flex flex-wrap gap-2 justify-start">
                {exp.technologies.map((tech) => (
                  <span class="text-xs px-2 py-1 bg-zinc-800 text-zinc-300 rounded">
                    {tech}
                  </span>
                ))}
              </div>
            )}

            <!-- Type Badge -->
            <div class="mt-4">
              <span class="inline-flex items-center gap-1.5 text-xs font-bold px-2 py-1 rounded bg-zinc-800 border border-zinc-700 text-zinc-400">
                {exp.type === 'work' ? (
                  <>
                    <Briefcase size={12} />
                    Work
                  </>
                ) : (
                  <>
                    <GraduationCap size={12} />
                    Education
                  </>
                )}
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline-item {
    opacity: 0;
  }

  .animate-timeline {
    animation: slideInTimeline 0.6s ease-out forwards;
  }

  @keyframes slideInTimeline {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .timeline-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.5);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(255, 255, 255, 0);
    }
  }

  .timeline-line {
    animation: growLine 2s ease-out forwards;
  }

  @keyframes growLine {
    from {
      transform: scaleY(0);
      transform-origin: top;
    }
    to {
      transform: scaleY(1);
      transform-origin: top;
    }
  }
</style>
