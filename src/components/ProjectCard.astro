---
import { Github, ExternalLink, Star, Users } from '@lucide/astro';

interface Props {
  name: string;
  description: string;
  technologies: string[];
  githubUrl?: string;
  liveUrl?: string;
  featured?: boolean;
  contributed?: boolean;
}

const { name, description, technologies, githubUrl, liveUrl, featured, contributed } = Astro.props;
---

<div class="group h-full bg-zinc-900/50 backdrop-blur-sm border border-zinc-800 rounded-lg p-6 hover:border-zinc-600 transition-all hover:shadow-xl hover:shadow-white/5">
  <!-- Badges -->
  <div class="flex gap-2 mb-4">
    {featured && (
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-300">
        <Star size={12} />
        Featured
      </span>
    )}
    {contributed && (
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full bg-zinc-800 border border-zinc-700 text-zinc-300">
        <Users size={12} />
        Contributed
      </span>
    )}
  </div>

  <!-- Project Name -->
  <h3 class="text-2xl font-bold text-white mb-3 group-hover:text-zinc-200 transition-colors">
    {name}
  </h3>

  <!-- Description -->
  <p class="text-zinc-400 mb-4 leading-relaxed">
    {description}
  </p>

  <!-- Technologies -->
  <div class="flex flex-wrap gap-2 mb-6">
    {technologies.map((tech) => (
      <span class="text-xs px-3 py-1 bg-zinc-800 text-zinc-300 rounded-full border border-zinc-700">
        {tech}
      </span>
    ))}
  </div>

  <!-- Links -->
  <div class="flex gap-4 mt-auto">
    {githubUrl && (
      <a 
        href={githubUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors"
      >
        <Github size={18} />
        View Code
      </a>
    )}
    {liveUrl && (
      <a 
        href={liveUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors"
      >
        <ExternalLink size={18} />
        Live Site
      </a>
    )}
  </div>
</div>
